@{
    ViewData["Title"] = "Downloads";
}

<section class="page-hero downloads-page-hero">
    <div class="container page-hero-content">
        <div class="eyebrow">
            <span class="server-status-dot"></span>
            MaximoRO Downloads
        </div>

        <h1>
            Prepare your client.
            <span>Your adventure begins here.</span>
        </h1>

        <p>
            Download links, installation instructions, launcher updates, and
            system requirements will be published here when the MaximoRO client
            is ready for testing.
        </p>
    </div>
</section>

<section class="section downloads-main-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Client availability
            </div>

            <h2>
                Everything needed to
                <span>enter MaximoRO.</span>
            </h2>

            <p>
                The client and launcher are not yet publicly available. These
                download cards will be activated after testing is complete.
            </p>
        </div>

        <div class="downloads-grid">
            <article class="download-card featured-download-card">
                <div class="download-card-icon">
                    <span>01</span>
                </div>

                <div class="download-card-content">
                    <span class="download-status unavailable">
                        Not yet available
                    </span>

                    <h2>Full MaximoRO Client</h2>

                    <p>
                        The recommended download for new players. This package
                        will include the complete game client, required data,
                        and the official MaximoRO launcher.
                    </p>

                    <dl class="download-details">
                        <div>
                            <dt>File type</dt>
                            <dd>Installer or archive</dd>
                        </div>

                        <div>
                            <dt>Estimated size</dt>
                            <dd>TBA</dd>
                        </div>

                        <div>
                            <dt>Version</dt>
                            <dd>Development build</dd>
                        </div>
                    </dl>

                    <button class="btn hero-primary-button download-disabled-button" type="button" disabled>
                        Download Unavailable
                    </button>
                </div>
            </article>

            <article class="download-card">
                <div class="download-card-icon">
                    <span>02</span>
                </div>

                <div class="download-card-content">
                    <span class="download-status unavailable">
                        Not yet available
                    </span>

                    <h2>Launcher Only</h2>

                    <p>
                        Intended for players who already have the correct client
                        files. The launcher will handle patches and future
                        updates automatically.
                    </p>

                    <dl class="download-details">
                        <div>
                            <dt>File type</dt>
                            <dd>Windows application</dd>
                        </div>

                        <div>
                            <dt>Estimated size</dt>
                            <dd>TBA</dd>
                        </div>

                        <div>
                            <dt>Version</dt>
                            <dd>TBA</dd>
                        </div>
                    </dl>

                    <button class="btn hero-secondary-button download-disabled-button" type="button" disabled>
                        Launcher Unavailable
                    </button>
                </div>
            </article>

            <article class="download-card">
                <div class="download-card-icon">
                    <span>03</span>
                </div>

                <div class="download-card-content">
                    <span class="download-status unavailable">
                        Coming later
                    </span>

                    <h2>Manual Patch</h2>

                    <p>
                        A manual patch option may be provided for players who
                        need to update an existing MaximoRO installation without
                        downloading the complete client again.
                    </p>

                    <dl class="download-details">
                        <div>
                            <dt>File type</dt>
                            <dd>Patch archive</dd>
                        </div>

                        <div>
                            <dt>Estimated size</dt>
                            <dd>TBA</dd>
                        </div>

                        <div>
                            <dt>Version</dt>
                            <dd>TBA</dd>
                        </div>
                    </dl>

                    <button class="btn hero-secondary-button download-disabled-button" type="button" disabled>
                        Patch Unavailable
                    </button>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="section installation-section">
    <div class="container installation-grid">
        <div class="installation-content">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Installation process
            </div>

            <h2>
                A simple path from
                <span>download to login.</span>
            </h2>

            <p>
                The final process may change as the launcher and account systems
                are developed, but players can expect a straightforward setup.
            </p>

            <ol class="installation-steps">
                <li>
                    <span>01</span>

                    <div>
                        <h3>Download the client</h3>
                        <p>
                            Obtain the official package only from this website
                            or an approved MaximoRO source.
                        </p>
                    </div>
                </li>

                <li>
                    <span>02</span>

                    <div>
                        <h3>Extract or install</h3>
                        <p>
                            Place the game in a folder where Windows allows the
                            launcher to update files.
                        </p>
                    </div>
                </li>

                <li>
                    <span>03</span>

                    <div>
                        <h3>Run the launcher</h3>
                        <p>
                            Allow the launcher to download the newest patches
                            before starting the game.
                        </p>
                    </div>
                </li>

                <li>
                    <span>04</span>

                    <div>
                        <h3>Create an account</h3>
                        <p>
                            Account registration instructions will be provided
                            before public testing begins.
                        </p>
                    </div>
                </li>
            </ol>
        </div>

        <aside class="requirements-panel">
            <div class="requirements-emblem">
                <img src="~/images/maximoro-emblem.png" alt="MaximoRO emblem" />
            </div>

            <span class="requirements-label">
                Planned platform
            </span>

            <h2>Windows PC</h2>

            <p>
                Final system requirements will be confirmed after the client,
                launcher, and graphical settings are tested.
            </p>

            <div class="requirements-list">
                <div>
                    <span>Operating system</span>
                    <strong>Windows 10 or newer</strong>
                </div>

                <div>
                    <span>Storage</span>
                    <strong>TBA</strong>
                </div>

                <div>
                    <span>Memory</span>
                    <strong>TBA</strong>
                </div>

                <div>
                    <span>Internet</span>
                    <strong>Broadband connection</strong>
                </div>
            </div>
        </aside>
    </div>
</section>

<section class="download-safety-section">
    <div class="container">
        <div class="download-safety-panel">
            <div>
                <div class="eyebrow">
                    <span class="server-status-dot"></span>
                    Download safely
                </div>

                <h2>Use official MaximoRO files only.</h2>

                <p>
                    Never download the client, launcher, or patches from unknown
                    users. Official mirrors and file checks will be listed on
                    this page when downloads become available.
                </p>
            </div>

            <a class="btn hero-secondary-button" asp-controller="Home" asp-action="Discord">
                Join Discord
            </a>
        </div>
    </div>
</section>