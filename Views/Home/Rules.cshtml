@{
    ViewData["Title"] = "Rules";
}

<section class="page-hero rules-page-hero">
    <div class="container page-hero-content">
        <div class="eyebrow">
            <span class="server-status-dot"></span>
            MaximoRO Rules
        </div>

        <h1>
            Fair play protects
            <span>the entire community.</span>
        </h1>

        <p>
            These rules are designed to keep MaximoRO welcoming, competitive,
            and enjoyable. Every player is responsible for understanding and
            following them.
        </p>
    </div>
</section>

<section class="section rules-introduction-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Community standards
            </div>

            <h2>
                Respect the players.
                <span>Respect the world.</span>
            </h2>

            <p>
                Rules may be expanded as MaximoRO systems are implemented and
                tested. Major changes will be announced through the News page
                and Discord.
            </p>
        </div>

        <div class="rules-principles-grid">
            <article class="rules-principle-card">
                <span class="rules-principle-number">01</span>
                <h3>Play Fair</h3>
                <p>
                    Do not use unauthorized programs, exploits, automation, or
                    unintended mechanics to gain an advantage.
                </p>
            </article>

            <article class="rules-principle-card">
                <span class="rules-principle-number">02</span>
                <h3>Respect Others</h3>
                <p>
                    Harassment, threats, discrimination, impersonation, and
                    targeted abuse are not permitted.
                </p>
            </article>

            <article class="rules-principle-card">
                <span class="rules-principle-number">03</span>
                <h3>Protect the Economy</h3>
                <p>
                    Scamming, fraudulent trades, real-money trading, and abuse
                    of economic systems may result in account action.
                </p>
            </article>
        </div>
    </div>
</section>

<section class="section rules-list-section">
    <div class="container rules-layout">
        <aside class="rules-sidebar">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Rule categories
            </div>

            <h2>Know what is expected.</h2>

            <p>
                Ignorance of the rules does not prevent disciplinary action.
                Staff may act against behavior that harms the server even when
                a specific situation is not listed word for word.
            </p>

            <div class="rules-sidebar-notice">
                <strong>Important</strong>

                <p>
                    Keep screenshots, videos, timestamps, and character names
                    when reporting serious violations.
                </p>
            </div>
        </aside>

        <div class="rules-category-list">
            <article class="rules-category-card">
                <div class="rules-category-heading">
                    <span>01</span>

                    <div>
                        <h3>Player Conduct</h3>
                        <p>Behavior in-game and throughout the community.</p>
                    </div>
                </div>

                <ul>
                    <li>Do not harass, threaten, stalk, or repeatedly target another player.</li>
                    <li>Do not use discriminatory, hateful, or sexually explicit language.</li>
                    <li>Do not impersonate staff members or other players.</li>
                    <li>Do not intentionally disrupt public chats with spam or excessive advertising.</li>
                    <li>Do not share another person's private information.</li>
                </ul>
            </article>

            <article class="rules-category-card">
                <div class="rules-category-heading">
                    <span>02</span>

                    <div>
                        <h3>Cheating and Exploitation</h3>
                        <p>Unauthorized tools and abuse of game systems.</p>
                    </div>
                </div>

                <ul>
                    <li>Do not use bots, macros, packet tools, speed hacks, or modified clients.</li>
                    <li>Do not exploit bugs, duplication methods, or unintended reward loops.</li>
                    <li>Report serious exploits privately rather than sharing them publicly.</li>
                    <li>Do not assist another player in hiding or benefiting from an exploit.</li>
                    <li>Staff may remove items, currency, or progress gained unfairly.</li>
                </ul>
            </article>

            <article class="rules-category-card">
                <div class="rules-category-heading">
                    <span>03</span>

                    <div>
                        <h3>Trading and Economy</h3>
                        <p>Fair exchange between players.</p>
                    </div>
                </div>

                <ul>
                    <li>Real-money trading of accounts, currency, or items is prohibited.</li>
                    <li>Do not misrepresent an item or intentionally deceive another player.</li>
                    <li>Account sharing and lending are performed at the owner's risk.</li>
                    <li>Staff are not responsible for informal loans or poorly documented trades.</li>
                    <li>Suspicious transactions may be reviewed or reversed.</li>
                </ul>
            </article>

            <article class="rules-category-card">
                <div class="rules-category-heading">
                    <span>04</span>

                    <div>
                        <h3>Guilds, Parties, and Competition</h3>
                        <p>Competitive play without destructive behavior.</p>
                    </div>
                </div>

                <ul>
                    <li>Competitive rivalry does not excuse harassment or threats.</li>
                    <li>Do not sabotage events through exploits or intentional server disruption.</li>
                    <li>Guild names, emblems, and recruitment messages must follow conduct rules.</li>
                    <li>War of Emperium rules will be published before the system launches.</li>
                    <li>Organized match-fixing or reward manipulation is prohibited.</li>
                </ul>
            </article>

            <article class="rules-category-card">
                <div class="rules-category-heading">
                    <span>05</span>

                    <div>
                        <h3>Accounts and Security</h3>
                        <p>Protecting access to your characters and items.</p>
                    </div>
                </div>

                <ul>
                    <li>Never share your password with anyone claiming to be staff.</li>
                    <li>Use a unique password that is not reused on other services.</li>
                    <li>You are responsible for activity performed through your account.</li>
                    <li>Do not buy, sell, or trade MaximoRO accounts.</li>
                    <li>Report suspected account compromise as soon as possible.</li>
                </ul>
            </article>

            <article class="rules-category-card">
                <div class="rules-category-heading">
                    <span>06</span>

                    <div>
                        <h3>Staff and Enforcement</h3>
                        <p>How reports and disciplinary actions are handled.</p>
                    </div>
                </div>

                <ul>
                    <li>Do not publicly harass staff over a warning, mute, suspension, or ban.</li>
                    <li>Appeals must be submitted through the official support process.</li>
                    <li>False reports and fabricated evidence may result in punishment.</li>
                    <li>Penalties may include warnings, mutes, item removal, suspension, or permanent bans.</li>
                    <li>Severe violations may receive immediate action without prior warnings.</li>
                </ul>
            </article>
        </div>
    </div>
</section>

<section class="rules-enforcement-section">
    <div class="container">
        <div class="rules-enforcement-panel">
            <div>
                <div class="eyebrow">
                    <span class="server-status-dot"></span>
                    Enforcement policy
                </div>

                <h2>Context and severity matter.</h2>

                <p>
                    Staff will consider intent, impact, prior violations, and
                    available evidence when reviewing a case. Repeated or
                    deliberate violations may receive stronger penalties.
                </p>
            </div>

            <div class="rules-enforcement-levels">
                <div>
                    <span>Level I</span>
                    <strong>Warning or mute</strong>
                </div>

                <div>
                    <span>Level II</span>
                    <strong>Temporary suspension</strong>
                </div>

                <div>
                    <span>Level III</span>
                    <strong>Permanent removal</strong>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="final-cta-section">
    <div class="container">
        <div class="final-cta-panel">
            <div class="final-cta-emblem">
                <img src="~/images/maximoro-emblem.png" alt="MaximoRO emblem" />
            </div>

            <div class="final-cta-content">
                <div class="eyebrow">
                    <span class="server-status-dot"></span>
                    Need assistance?
                </div>

                <h2>Report concerns through official channels.</h2>

                <p>
                    Join the MaximoRO Discord for announcements, support
                    information, and the future reporting process.
                </p>
            </div>

            <div class="final-cta-actions">
                <a class="btn hero-primary-button" asp-controller="Home" asp-action="Discord">
                    Join Discord
                </a>

                <a class="btn hero-secondary-button" asp-controller="Home" asp-action="News">
                    Read Updates
                </a>
            </div>
        </div>
    </div>
</section>