@{
    ViewData["Title"] = "Features";
}

<section class="page-hero features-page-hero">
    <div class="container page-hero-content">
        <div class="eyebrow">
            <span class="server-status-dot"></span>
            Discover MaximoRO
        </div>

        <h1>
            Classic adventure,
            <span>thoughtfully expanded.</span>
        </h1>

        <p>
            MaximoRO preserves the social progression and memorable exploration
            of Ragnarok Online while introducing balanced improvements, active
            events, and community-focused systems.
        </p>
    </div>
</section>

<section class="section features-overview-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                The MaximoRO experience
            </div>

            <h2>
                Built around the parts of RO
                <span>players remember most.</span>
            </h2>

            <p>
                Explore, build your character, trade with other players, challenge
                dangerous enemies, and create lasting memories with your guild.
            </p>
        </div>

        <div class="feature-detail-grid">
            <article class="feature-detail-card">
                <span class="feature-detail-number">01</span>
                <div class="feature-detail-icon">⚔</div>

                <h3>Rewarding Progression</h3>

                <p>
                    Develop your character through meaningful leveling, equipment
                    upgrades, class advancement, quests, and exploration.
                </p>

                <ul>
                    <li>Character and job progression</li>
                    <li>Equipment and card collection</li>
                    <li>Multiple paths for advancement</li>
                </ul>
            </article>

            <article class="feature-detail-card">
                <span class="feature-detail-number">02</span>
                <div class="feature-detail-icon">♜</div>

                <h3>Classic World Exploration</h3>

                <p>
                    Travel through iconic towns, fields, caves, ruins, and
                    dangerous dungeons filled with monsters and hidden rewards.
                </p>

                <ul>
                    <li>Recognizable towns and regions</li>
                    <li>Party-oriented dungeon content</li>
                    <li>Secrets worth discovering</li>
                </ul>
            </article>

            <article class="feature-detail-card">
                <span class="feature-detail-number">03</span>
                <div class="feature-detail-icon">✦</div>

                <h3>Active Community</h3>

                <p>
                    MaximoRO is designed to encourage cooperation, trading,
                    conversation, guild-building, and shared adventures.
                </p>

                <ul>
                    <li>Community events</li>
                    <li>Parties and guild progression</li>
                    <li>Player feedback and transparency</li>
                </ul>
            </article>

            <article class="feature-detail-card">
                <span class="feature-detail-number">04</span>
                <div class="feature-detail-icon">♛</div>

                <h3>MVP and Boss Hunting</h3>

                <p>
                    Challenge powerful monsters with coordinated parties and
                    compete for rare equipment, cards, and prestige.
                </p>

                <ul>
                    <li>Classic MVP encounters</li>
                    <li>Group-oriented challenges</li>
                    <li>Rare and memorable rewards</li>
                </ul>
            </article>

            <article class="feature-detail-card">
                <span class="feature-detail-number">05</span>
                <div class="feature-detail-icon">⚑</div>

                <h3>Guild Competition</h3>

                <p>
                    Build alliances, organize strategies, and prepare your guild
                    for competitive and cooperative server activities.
                </p>

                <ul>
                    <li>Guild identity and teamwork</li>
                    <li>Competitive objectives</li>
                    <li>Long-term community rivalries</li>
                </ul>
            </article>

            <article class="feature-detail-card">
                <span class="feature-detail-number">06</span>
                <div class="feature-detail-icon">☼</div>

                <h3>Events and Updates</h3>

                <p>
                    Participate in seasonal celebrations, server-wide activities,
                    development updates, and rotating community challenges.
                </p>

                <ul>
                    <li>Seasonal events</li>
                    <li>Regular development updates</li>
                    <li>New activities over time</li>
                </ul>
            </article>
        </div>
    </div>
</section>

<section class="section feature-showcase-section">
    <div class="container feature-showcase-grid">
        <div class="feature-showcase-image">
            <img src="~/images/features/build-your-character.png"
                 alt="A high-level fantasy adventurer in powerful armor" />
        </div>

        <div class="feature-showcase-content">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                More than solo progression
            </div>

            <h2>
                Build a character.
                <span>Become part of a world.</span>
            </h2>

            <p>
                Ragnarok Online is remembered not only for its classes and
                monsters, but for the people encountered along the way. MaximoRO
                is being designed to make parties, guilds, trading, and community
                interaction matter.
            </p>

            <a class="btn hero-primary-button" asp-controller="Home" asp-action="Discord">
                Join the Community
            </a>
        </div>
    </div>
</section>

<section class="final-cta-section">
    <div class="container">
        <div class="final-cta-panel">
            <div class="final-cta-emblem">
                <img src="~/images/maximoro-emblem.png" alt="MaximoRO emblem" />
            </div>

            <div class="final-cta-content">
                <div class="eyebrow">
                    <span class="server-status-dot"></span>
                    Learn the details
                </div>

                <h2>Ready to see how the server works?</h2>

                <p>
                    Review the rates, level limits, server style, and launch
                    information on the Server Info page.
                </p>
            </div>

            <div class="final-cta-actions">
                <a class="btn hero-primary-button" asp-controller="Home" asp-action="ServerInfo">
                    Server Information
                </a>

                <a class="btn hero-secondary-button" asp-controller="Home" asp-action="Downloads">
                    Downloads
                </a>
            </div>
        </div>
    </div>
</section>