@{
    ViewData["Title"] = "News";
    ViewData["MetaDescription"] = "Search MaximoRO patch updates, progression changes, community announcements, events, and development news.";
}

<section class="page-hero news-page-hero">
    <div class="container page-hero-content">
        <div class="eyebrow">
            <span class="server-status-dot"></span>
            MaximoRO News
        </div>

        <h1>
            Development updates,
            <span>events, and announcements.</span>
        </h1>

        <p>
            Follow the progress of MaximoRO, review important announcements,
            and stay informed about upcoming tests, events, and server changes.
        </p>
    </div>
</section>

<section class="section news-page-section" data-collection-root>
    <div class="container">
        <div class="section-heading">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Latest updates
            </div>

            <h2>
                What is happening
                <span>around MaximoRO.</span>
            </h2>

            <p>
                New development posts and community announcements will appear
                here as work on the server continues.
            </p>
        </div>

        <div class="content-filter-toolbar">
            <div class="content-search-field">
                <label for="update-search">Search updates</label>
                <input id="update-search" type="search" placeholder="Search patch notes and announcements" autocomplete="off" data-collection-search />
            </div>

            <div class="content-filter-tabs" role="group" aria-label="Filter updates">
                <button type="button" class="active" data-collection-filter="all" aria-pressed="true">All</button>
                <button type="button" data-collection-filter="patch" aria-pressed="false">Patches</button>
                <button type="button" data-collection-filter="development" aria-pressed="false">Development</button>
                <button type="button" data-collection-filter="community" aria-pressed="false">Community</button>
                <button type="button" data-collection-filter="guide" aria-pressed="false">Guides</button>
                <button type="button" data-collection-filter="event" aria-pressed="false">Events</button>
            </div>

            <span class="content-result-count" data-collection-count aria-live="polite">8 updates</span>
        </div>

        <div class="content-empty-state" data-collection-empty hidden>
            <strong>No matching updates</strong>
            <span>Try a different search or category.</span>
        </div>

        <div class="news-page-grid">
            <article class="news-page-card featured-news-card advancement-training-news-card"
                     data-collection-item
                     data-collection-category="patch">
                <div class="news-page-image news-image-advancement-training"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Patch Notes</span>
                        <time datetime="2026-07-23">July 23, 2026</time>
                    </div>

                    <h2>Pathfinder Overhaul: Advancement Training Update</h2>

                    <p>
                        Pathfinder guidance now continues through Level 50 with
                        three new advancement routes, open destination review,
                        direct travel, and a streamlined field network of
                        Pathfinder Envoys.
                    </p>

                    <div class="pathfinder-feature-list"
                         aria-label="Advancement Training patch features">
                        <span>Levels 35-50</span>
                        <span>Three training grounds</span>
                        <span>Class-aware guidance</span>
                        <span>Open route choice</span>
                        <span>Pathfinder Envoys</span>
                        <span>Cleaner field support</span>
                    </div>

                    <a class="news-read-more"
                       asp-controller="Home"
                       asp-action="AdvancementTrainingPatch">
                        Read the patch notes
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="news-page-card featured-news-card pathfinder-news-card" data-collection-item data-collection-category="development">
                <div class="news-page-image news-image-journey-forward"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Development Update</span>
                        <time datetime="2026-07-23">July 23, 2026</time>
                    </div>

                    <h2>The journey forward: progression, localization, and safer accounts</h2>

                    <p>
                        Today's work connects a clearer Level 35 handoff,
                        expanded Pathfinder and Kafra support, stat and skill
                        resets, English client localization, live verified
                        registration, clearer form feedback, and a more reliable
                        website deployment. The next progression focus is the
                        Level 35-50 journey.
                    </p>

                    <div class="pathfinder-feature-list" aria-label="Development update topics">
                        <span>Level 35 handoff</span>
                        <span>Pathfinder hub</span>
                        <span>Kafra services</span>
                        <span>Skill resets</span>
                        <span>English localization</span>
                        <span>Verified registration</span>
                    </div>

                    <a class="news-read-more"
                       asp-controller="Home"
                       asp-action="JourneyForwardUpdate">
                        Read the full development update
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="news-page-card featured-news-card pathfinder-news-card" data-collection-item data-collection-category="patch">
                <div class="news-page-image news-image-pathfinder"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Patch Update</span>
                        <time datetime="2026-07-21">July 21, 2026</time>
                    </div>

                    <h2>The MaximoRO Pathfinder is now guiding new adventurers</h2>

                    <p>
                        The Criatura Academy now connects directly into MaximoRO's
                        custom beginner progression. After completing a first-job
                        change, players can continue through class guidance,
                        hunting routes, assignments, supplies, healing, and
                        beginner transportation.
                    </p>

                    <div class="pathfinder-feature-list" aria-label="Pathfinder features">
                        <span>Class guidance</span>
                        <span>Hunting routes</span>
                        <span>Weekly supplies</span>
                        <span>Beginner healing</span>
                        <span>First assignment</span>
                        <span>Guided navigation</span>
                    </div>

                    <div class="pathfinder-flow" aria-label="Updated beginner progression">
                        <span>Shipwreck</span>
                        <span aria-hidden="true">→</span>
                        <span>Izlude</span>
                        <span aria-hidden="true">→</span>
                        <span>Criatura Academy</span>
                        <span aria-hidden="true">→</span>
                        <span>First Job</span>
                        <span aria-hidden="true">→</span>
                        <strong>Pathfinder</strong>
                    </div>

                    <a class="news-read-more"
                       asp-controller="Home"
                       asp-action="ProgressionPatch"
                       asp-fragment="pathfinder">
                        Explore the Progression Patch
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="news-page-card" data-collection-item data-collection-category="patch">
                <div class="news-page-image news-image-guide"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Progression Patch</span>
                        <time datetime="2026-07-21">July 21, 2026</time>
                    </div>

                    <h2>Build Adviser and class guides are now connected</h2>

                    <p>
                        MaximoRO now connects in-game class guidance with the
                        website's expanded Stats and Builds guide. Players can
                        review beginner stat priorities, open the correct class
                        section directly, and use protected early-game stat resets.
                    </p>

                    <div class="pathfinder-feature-list"
                         aria-label="Build Adviser and guide features">
                        <span>Class guides</span>
                        <span>Stat explanations</span>
                        <span>Build guidance</span>
                        <span>Direct guide links</span>
                        <span>Stat resets</span>
                        <span>Pathfinder access</span>
                    </div>

                    <a class="news-read-more"
                       asp-controller="Home"
                       asp-action="ProgressionPatch"
                       asp-fragment="guides-and-builds">
                        Explore guides and builds
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>
            <article class="news-page-card" data-collection-item data-collection-category="development">
                <div class="news-page-image news-image-development"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Development</span>
                        <time datetime="2026-07-17">July 17, 2026</time>
                    </div>

                    <h2>Building the foundation of MaximoRO</h2>

                    <p>
                        Work has begun on the MaximoRO website, visual identity,
                        server information pages, and development structure.
                        The project is currently in its early foundation stage.
                    </p>

                    <a class="news-read-more" asp-controller="Home" asp-action="ServerInfo">
                        View server progress
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="news-page-card" data-collection-item data-collection-category="community">
                <div class="news-page-image news-image-community"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Community</span>
                        <time datetime="2026-07-17">July 17, 2026</time>
                    </div>

                    <h2>A community-first server experience</h2>

                    <p>
                        MaximoRO is being designed around parties, guilds,
                        trading, events, and meaningful interaction between
                        players rather than isolated solo progression.
                    </p>

                    <a class="news-read-more" asp-controller="Home" asp-action="Features">
                        Explore the features
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="news-page-card" data-collection-item data-collection-category="guide">
                <div class="news-page-image news-image-guide"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Guide</span>
                        <time datetime="2026-07-17">July 17, 2026</time>
                    </div>

                    <h2>Preparing for your first adventure</h2>

                    <p>
                        Installation instructions, account registration,
                        launcher details, and beginner information will be
                        published before public testing begins.
                    </p>

                    <a class="news-read-more" asp-controller="Home" asp-action="Downloads">
                        Visit downloads
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="news-page-card" data-collection-item data-collection-category="event">
                <div class="news-page-image news-image-event"></div>

                <div class="news-page-card-content">
                    <div class="news-card-meta">
                        <span>Events</span>
                        <time datetime="2026-07-17">July 17, 2026</time>
                    </div>

                    <h2>Future events and community activities</h2>

                    <p>
                        Seasonal celebrations, automated activities, GM-hosted
                        events, and community competitions are being considered
                        for future development.
                    </p>

                    <a class="news-read-more" asp-controller="Home" asp-action="Discord">
                        Join the community
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="news-development-banner">
    <div class="container">
        <div class="news-development-panel">
            <div>
                <div class="eyebrow">
                    <span class="server-status-dot"></span>
                    Development notice
                </div>

                <h2>MaximoRO is still under active development.</h2>

                <p>
                    Server settings, systems, features, and release dates may
                    change as testing continues. Confirmed details will be
                    published here when they are ready.
                </p>
            </div>

            <a class="btn hero-primary-button" asp-controller="Home" asp-action="Discord">
                Follow on Discord
            </a>
        </div>
    </div>
</section>
