@{
    ViewData["Title"] = "Server Info";
}

<section class="page-hero server-info-page-hero">
    <div class="container page-hero-content">
        <div class="eyebrow">
            <span class="server-status-dot"></span>
            Server information
        </div>

        <h1>
            Everything you need to know
            <span>before entering MaximoRO.</span>
        </h1>

        <p>
            Review the current server style, progression settings, development
            status, and launch information. Any undecided values are clearly
            marked as TBA while development continues.
        </p>
    </div>
</section>

<section class="section server-info-overview">
    <div class="container">
        <div class="section-heading centered-heading">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Current server profile
            </div>

            <h2>
                A clear look at
                <span>how MaximoRO is being built.</span>
            </h2>

            <p>
                These settings will be updated as the server is configured,
                tested, and finalized.
            </p>
        </div>

        <div class="server-info-grid">
            <article class="server-info-card">
                <span class="server-info-label">Server Status</span>

                <strong data-server-status-text>
                    Checking...
                </strong>

                <p>
                    <strong data-player-count>0</strong>
                    players currently online.
                </p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Server Style</span>
                <strong>Renewal</strong>
                <p>
                    Renewal mechanics and progression powered by the current rAthena setup.
                </p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Login Server</span>
                <strong data-login-server-status>
                    Checking...
                </strong>
                <p>Handles account authentication and initial connection.</p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Character Server</span>
                <strong data-char-server-status>
                    Checking...
                </strong>
                <p>Handles character selection, creation, and character data.</p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Map Server</span>
                <strong data-map-server-status>
                    Checking...
                </strong>
                <p>Runs maps, monsters, NPCs, combat, and active gameplay.</p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Base Experience</span>
                <strong>7.5×</strong>
                <p>Accelerated leveling that keeps progression meaningful without feeling excessively slow.</p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Job Experience</span>
                <strong>7.5×</strong>
                <p>Faster job progression while preserving the importance of class advancement.</p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Item Drop Rate</span>
                <strong>5× / 3×</strong>
                <p>Common, healing, and usable items are 5×. Normal equipment drops are 3×.</p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Card Drop Rate</span>
                <strong>3× / 1×</strong>
                <p>Normal monster cards are 3×, while boss and MVP cards remain at 1×.</p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Boss & MVP Drops</span>
                <strong>2×</strong>
                <p>Boss and MVP non-card drops, including direct MVP rewards, use a 2× rate.</p>
            </article>


            <article class="server-info-card">
                <span class="server-info-label">Maximum Base Level</span>
                <strong>Up to 275</strong>
                <p>
                    Base-level limits vary by class and progression tier.
                </p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Maximum Job Level</span>
                <strong>Up to 99</strong>
                <p>
                    Job-level limits vary by class, with many classes capped at 50, 60, or 70.
                </p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Content Era</span>
                <strong>Modern Renewal</strong>
                <p>
                    MaximoRO uses a modern Renewal client and content base while the launch content scope is finalized.
                </p>
            </article>

            <article class="server-info-card">
                <span class="server-info-label">Client Version</span>
                <strong>2026-02-19</strong>
                <p>The current MaximoRO client and active server packet version.</p>
            </article>
        </div>
    </div>
</section>

<section class="section server-details-section">
    <div class="container server-details-grid">
        <div class="server-details-panel">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Gameplay details
            </div>

            <h2>Systems currently under review</h2>

            <ul class="server-details-list">
                <li>
                    <span>01</span>
                    Reset rules and character build flexibility
                </li>

                <li>
                    <span>02</span>
                    Dual-client and multi-client policy
                </li>

                <li>
                    <span>03</span>
                    War of Emperium schedule and settings
                </li>

                <li>
                    <span>04</span>
                    Economy, vending, storage, and trading rules
                </li>

                <li>
                    <span>05</span>
                    Custom NPCs, quests, rewards, and events
                </li>

                <li>
                    <span>06</span>
                    Donation policy and non-pay-to-win safeguards
                </li>
            </ul>
        </div>

        <div class="server-development-panel">
            <div class="development-status-card">
                <span class="development-status-label">Development Stage</span>
                <strong>Early Development</strong>

                <p>
                    The website foundation is active while the game server,
                    database, client, and launcher systems are inspected,
                    configured, and tested.
                </p>

                <div class="development-progress">
                    <div class="development-progress-bar"></div>
                </div>

                <span class="development-progress-text">
                    Website foundation in progress
                </span>
            </div>
        </div>
    </div>
</section>

<section class="final-cta-section">
    <div class="container">
        <div class="final-cta-panel">
            <div class="final-cta-emblem">
                <img src="~/images/maximoro-emblem.png" alt="MaximoRO emblem" />
            </div>

            <div class="final-cta-content">
                <div class="eyebrow">
                    <span class="server-status-dot"></span>
                    Follow development
                </div>

                <h2>Stay informed as MaximoRO takes shape.</h2>

                <p>
                    Visit the News page for updates or join Discord to follow
                    development and community announcements.
                </p>
            </div>

            <div class="final-cta-actions">
                <a class="btn hero-primary-button" asp-controller="Home" asp-action="News">
                    Latest News
                </a>

                <a class="btn hero-secondary-button" asp-controller="Home" asp-action="Discord">
                    Join Discord
                </a>
            </div>
        </div>
    </div>
</section>