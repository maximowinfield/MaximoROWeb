@model MaximoROWeb.Models.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
}

<section class="page-section account-section">
    <div class="account-shell">
        <div class="account-intro">
            <span class="eyebrow">Join MaximoRO</span>
            <h1>Create Your Account</h1>
            <p>
                Register your game account, download the client, and begin your
                adventure in Rune-Midgard.
            </p>

            <div class="account-notice">
                <strong>Use a unique password.</strong>
                <span>
                    Do not reuse a password from your email, banking, or other
                    important accounts.
                </span>
            </div>
        </div>

        <div class="account-card">
            @if (TempData["RegistrationSuccess"] is string successMessage)
            {
                <div class="form-alert form-alert-success" role="status">
                    @successMessage
                </div>
            }

            <form asp-action="Register" method="post">
                <div class="registration-honeypot" aria-hidden="true">
                    <label asp-for="Website"></label>

                    <input asp-for="Website" tabindex="-1" autocomplete="off" />
                </div>
                <div asp-validation-summary="ModelOnly" class="form-alert form-alert-error"></div>

                <div class="form-field">
                    <label asp-for="Username"></label>
                    <input asp-for="Username" autocomplete="username" maxlength="23" />
                    <span asp-validation-for="Username"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" autocomplete="email" maxlength="39" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" autocomplete="new-password" maxlength="23" />
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="form-field">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" autocomplete="new-password" maxlength="23" />
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>

                <fieldset class="form-field">
                    <legend>Character Sex</legend>

                    <div class="radio-group">
                        <label class="radio-option">
                            <input asp-for="Sex" type="radio" value="M" />
                            <span>Male</span>
                        </label>

                        <label class="radio-option">
                            <input asp-for="Sex" type="radio" value="F" />
                            <span>Female</span>
                        </label>
                    </div>

                    <span asp-validation-for="Sex"></span>
                </fieldset>

                <button class="button button-primary account-submit" type="submit">
                    Create Account
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}