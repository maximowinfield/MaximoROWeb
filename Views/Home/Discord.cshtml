@{
    ViewData["Title"] = "Discord";
}

<section class="page-hero discord-page-hero">
    <div class="container page-hero-content">
        <div class="eyebrow">
            <span class="server-status-dot"></span>
            MaximoRO Community
        </div>

        <h1>
            Adventure is better
            <span>with a community.</span>
        </h1>

        <p>
            Join the MaximoRO Discord to follow development, meet other players,
            find guilds, receive support, and stay informed about upcoming
            testing and server announcements.
        </p>

        <div class="page-hero-actions">
            <a class="btn hero-primary-button" href="https://discord.gg/JWGgmvGwAa" target="_blank"
               rel="noopener noreferrer">
                Join the Discord
            </a>

            <a class="btn hero-secondary-button" asp-controller="Home" asp-action="News">
                Read Updates
            </a>
        </div>
    </div>
</section>

<section class="section discord-benefits-section">
    <div class="container">
        <div class="section-heading centered-heading">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Community headquarters
            </div>

            <h2>
                Stay connected
                <span>through every stage.</span>
            </h2>

            <p>
                Discord will serve as the central place for development news,
                player discussion, support, guild recruitment, and future
                event coordination.
            </p>
        </div>

        <div class="discord-benefits-grid">
            <article class="discord-benefit-card">
                <span class="discord-benefit-number">01</span>

                <h3>Development Updates</h3>

                <p>
                    Follow new systems, website changes, testing progress,
                    balance decisions, and launch announcements.
                </p>
            </article>

            <article class="discord-benefit-card">
                <span class="discord-benefit-number">02</span>

                <h3>Player Support</h3>

                <p>
                    Ask questions, report issues, review announcements, and
                    find official instructions when support opens.
                </p>
            </article>

            <article class="discord-benefit-card">
                <span class="discord-benefit-number">03</span>

                <h3>Guild Recruitment</h3>

                <p>
                    Meet other adventurers, create parties, organize guilds,
                    and prepare for future competitive content.
                </p>
            </article>

            <article class="discord-benefit-card">
                <span class="discord-benefit-number">04</span>

                <h3>Events and Testing</h3>

                <p>
                    Receive notifications about closed tests, public testing,
                    community events, and future launch milestones.
                </p>
            </article>
        </div>
    </div>
</section>

<section class="section discord-community-section">
    <div class="container discord-community-grid">
        <div class="discord-community-content">
            <div class="eyebrow">
                <span class="server-status-dot"></span>
                Built around players
            </div>

            <h2>
                Help shape the future
                <span>of MaximoRO.</span>
            </h2>

            <p>
                MaximoRO is still under development, which means early
                community feedback can help identify confusing systems,
                technical problems, and opportunities for improvement.
            </p>

            <ul class="discord-community-list">
                <li>Follow official development announcements</li>
                <li>Share constructive feedback during testing</li>
                <li>Find parties, guilds, and future trading partners</li>
                <li>Receive support through official channels</li>
            </ul>
        </div>

        <div class="discord-invite-panel">
            <div class="discord-emblem">
                <img src="~/images/maximoro-emblem.png" alt="MaximoRO emblem" />
            </div>

            <span class="discord-panel-label">
                Official Community
            </span>

            <h2>MaximoRO Discord</h2>

            <p>
                Enter the community hub and follow the project as it develops.
            </p>

            <a class="btn hero-primary-button discord-join-button" href="https://discord.gg/JWGgmvGwAa" target="_blank"
               rel="noopener noreferrer">
                Accept Invite
            </a>

            <span class="discord-panel-note">
                Opens Discord in a new tab
            </span>
        </div>
    </div>
</section>

<section class="discord-guidelines-section">
    <div class="container">
        <div class="discord-guidelines-panel">
            <div>
                <div class="eyebrow">
                    <span class="server-status-dot"></span>
                    Community reminder
                </div>

                <h2>Respect applies everywhere.</h2>

                <p>
                    MaximoRO rules also apply within official community spaces.
                    Be respectful, avoid harassment, and follow staff guidance.
                </p>
            </div>

            <a class="btn hero-secondary-button" asp-controller="Home" asp-action="Rules">
                Review the Rules
            </a>
        </div>
    </div>
</section>