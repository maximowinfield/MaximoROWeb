@{
    string currentAction =
        ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";

    string currentController =
        ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";

    string IsActive(string action, string controller = "Home")
    {
        return string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
                ? "active"
                : string.Empty;
    }

    string IsControllerActive(string controller)
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;
    }

    string metaDescription =
        ViewData["MetaDescription"]?.ToString()
        ?? "MaximoRO is a community-focused Ragnarok Online Renewal server featuring guided progression, custom systems, events, and classic MMORPG adventure.";

    string socialImageUrl =
        $"{Context.Request.Scheme}://{Context.Request.Host}/images/social/maximoro-social-card.png";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <meta name="description" content="@metaDescription" />
    <meta name="theme-color" content="#08090d" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MaximoRO" />
    <meta property="og:title" content="@(ViewData["Title"]) | MaximoRO" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:image" content="@socialImageUrl" />
    <meta property="og:image:alt" content="MaximoRO adventurers overlooking a fantasy city" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(ViewData["Title"]) | MaximoRO" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image" content="@socialImageUrl" />

    <title>@ViewData["Title"] | MaximoRO</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body class="server-status-loading">
    <div class="site-background" aria-hidden="true">
        <div class="background-glow background-glow-left"></div>
        <div class="background-glow background-glow-right"></div>
    </div>

<header class="site-header">
    <nav class="navbar navbar-expand-lg navbar-dark main-navbar">
        <div class="container">
            <a class="navbar-brand server-brand"
               asp-controller="Home"
               asp-action="Index">
                <img src="~/images/MaximoRO.png"
                     alt="MaximoRO logo"
                     class="navbar-logo" />
            </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavigation"
                        aria-controls="mainNavigation"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse"
                     id="mainNavigation">

                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Index")"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @IsActive("Features")"
                               asp-controller="Home"
                               asp-action="Features">
                                Features
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @IsActive("ServerInfo")"
                               asp-controller="Home"
                               asp-action="ServerInfo">
                                Server Info
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @IsActive("News")"
                               asp-controller="Home"
                               asp-action="News">
                                News
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @IsControllerActive("Guides")"
                               asp-controller="Guides"
                               asp-action="Index">
                                Guides
                            </a>
                        </li>

<li class="nav-item">
    <a class="nav-link @IsActive("Rules")"
       asp-controller="Home"
       asp-action="Rules">
        Rules
    </a>
</li>

<li class="nav-item">
    <a class="nav-link @IsActive("Register")"
       asp-controller="Home"
       asp-action="Register">
        Register
    </a>
</li>

                        <li class="nav-item ms-lg-2">
                            <a class="nav-link nav-discord @IsActive("Discord")"
                               asp-controller="Home"
                               asp-action="Discord">
                                Discord
                            </a>
                        </li>

                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-download @IsActive("Downloads")"
                               asp-controller="Home"
                               asp-action="Downloads">
                                Client Status
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="server-utility-bar" aria-label="Live server information">
            <div class="container server-utility-content">
                <div class="server-utility-primary" aria-live="polite">
                    <span class="server-status-dot" aria-hidden="true"></span>
                    <strong data-server-status-text>Checking...</strong>
                    <span class="server-utility-separator" aria-hidden="true"></span>
                    <span>
                        <strong data-player-count>0</strong>
                        adventurers online
                    </span>
                </div>

                <dl class="server-utility-metrics">
                    <div>
                        <dt>Login</dt>
                        <dd data-login-server-status>Checking...</dd>
                    </div>
                    <div>
                        <dt>Character</dt>
                        <dd data-char-server-status>Checking...</dd>
                    </div>
                    <div>
                        <dt>World</dt>
                        <dd data-map-server-status>Checking...</dd>
                    </div>
                    <div>
                        <dt>Rates</dt>
                        <dd>7.5x / 7.5x</dd>
                    </div>
                    <div>
                        <dt>Client</dt>
                        <dd>2026-02-19</dd>
                    </div>
                </dl>

                <span class="server-utility-checked">
                    Checked <time data-status-checked>just now</time>
                </span>
            </div>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <a class="footer-brand"
                       asp-controller="Home"
                       asp-action="Index">
                        MaximoRO
                    </a>

                    <p class="footer-description">
                        A community-driven Ragnarok Online experience built
                        around adventure, progression, competition, and lasting
                        friendships.
                    </p>
                </div>

                <div class="footer-links">
                    <h2>Explore</h2>

                    <a asp-controller="Home"
                       asp-action="Features">
                        Features
                    </a>

                    <a asp-controller="Home"
                       asp-action="ServerInfo">
                        Server Information
                    </a>

                    <a asp-controller="Home"
                       asp-action="News">
                        Latest News
                    </a>
                    <a asp-controller="Guides"
                       asp-action="Index">
                        Player Guides
                    </a>
                </div>

                <div class="footer-links">
                    <h2>Community</h2>

                    <a asp-controller="Home"
                       asp-action="Rules">
                        Server Rules
                    </a>

                    <a asp-controller="Home"
                       asp-action="Discord">
                        Join Discord
                    </a>

                    <a asp-controller="Home"
                       asp-action="Downloads">
                        Downloads
                    </a>
                </div>
            </div>

            <div class="footer-bottom">
                <span>
                    &copy; @DateTime.Now.Year MaximoRO. All rights reserved.
                </span>

                <span>
                    MaximoRO is an independent fan project.
                </span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>